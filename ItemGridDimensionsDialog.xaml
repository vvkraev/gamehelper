<Window x:Class="GameHelper.ItemGridDimensionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сетка области предмета"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   MaxWidth="360"
                   Text="Выберите число столбцов (X) и строк (Y). После подтверждения выделите на экране прямоугольник — он будет разбит на ячейки."/>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Столбцов (X):" VerticalAlignment="Center" Width="110"/>
            <ComboBox x:Name="ComboX" Width="80" SelectionChanged="Combo_SelectionChanged"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="Строк (Y):" VerticalAlignment="Center" Width="110"/>
            <ComboBox x:Name="ComboY" Width="80" SelectionChanged="Combo_SelectionChanged"/>
        </StackPanel>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="OkBtn" Content="OK" Width="88" Margin="0,0,8,0" IsDefault="True" Click="Ok_OnClick"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="88" IsCancel="True" Click="Cancel_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
