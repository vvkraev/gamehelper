<Window x:Class="GameHelper.CraftLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лог крафта"
        Width="960" Height="640"
        MinWidth="480" MinHeight="300"
        Topmost="True">
    <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="8,8,8,4" LastChildFill="True">
            <Button x:Name="RefreshBtn"
                    DockPanel.Dock="Left"
                    Content="Обновить"
                    Width="80"
                    Margin="0,0,8,0"
                    Click="RefreshBtn_OnClick"/>
            <TextBlock x:Name="StatusText"
                       DockPanel.Dock="Right"
                       VerticalAlignment="Center"
                       Foreground="Gray"
                       Margin="8,0,0,0"
                       Text=""/>
            <TextBlock x:Name="FilePathText"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                       Text=""/>
        </DockPanel>
        <TextBox x:Name="LogContentBox"
                 Margin="8,0,8,8"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas"
                 FontSize="12"
                 TextWrapping="NoWrap"/>
    </DockPanel>
</Window>
