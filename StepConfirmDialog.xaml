<Window x:Class="GameHelper.StepConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Шаг крафта"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        MinWidth="380"
        MaxWidth="560">
    <Border Padding="20">
        <StackPanel>
            <TextBlock x:Name="MessageBlock"
                       TextWrapping="Wrap"
                       FontSize="14"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Продолжить: кнопка «Продолжить» или клавиша Enter."
                       Foreground="Gray"
                       TextWrapping="Wrap"
                       Margin="0,0,0,16"/>
            <Button x:Name="ContinueBtn"
                    Content="Продолжить"
                    IsDefault="True"
                    HorizontalAlignment="Right"
                    MinWidth="130"
                    Padding="14,8"
                    Click="Continue_OnClick"/>
        </StackPanel>
    </Border>
</Window>
