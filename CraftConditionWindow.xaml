<Window x:Class="GameHelper.CraftConditionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Условие остановки крафта"
        Height="580"
        Width="720"
        MinHeight="400"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel>
        <Grid DockPanel.Dock="Bottom" Margin="12,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="Копировать для отчёта…"
                    Padding="8,4"
                    Click="CopyForReport_OnClick"
                    ToolTip="Текущее состояние окна: кратко + JSON — без нажатия OK."/>
            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="OK"
                        Width="96"
                        Padding="8,4"
                        IsDefault="True"
                        Click="Ok_OnClick"/>
                <Button Content="Отмена"
                        Width="96"
                        Padding="8,4"
                        Margin="12,0,0,0"
                        IsCancel="True"
                        Click="Cancel_OnClick"/>
            </StackPanel>
        </Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="14" x:Name="RootPanel">
                <TextBlock Text="Класс предмета" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="ItemClassCombo"
                          Margin="0,0,0,10"
                          SelectionChanged="ItemClassCombo_OnSelectionChanged"/>
                <StackPanel x:Name="SubClassRow" Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock Text="Тип планшета" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="TabletSubClassCombo"
                              SelectionChanged="TabletSubClassCombo_OnSelectionChanged"/>
                </StackPanel>
                <StackPanel x:Name="ArmourSubTypeRow" Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock Text="Подтип базы" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="ArmourSubTypeCombo"
                              SelectionChanged="ArmourSubTypeCombo_OnSelectionChanged"/>
                </StackPanel>
                <StackPanel x:Name="RuneRow" Visibility="Collapsed" Margin="0,0,0,10">
                    <TextBlock Text="Вставлена руна" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="RuneCombo"
                              SelectionChanged="RuneCombo_OnSelectionChanged"
                              ToolTip="Руна, вставленная в гнездо предмета — её аффиксы добавляются в пул крафта"/>
                </StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Орб (для весового расчёта)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <ComboBox x:Name="CraftOrbCombo"
                                  SelectionChanged="CraftOrbCombo_OnSelectionChanged"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Item Level" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBox x:Name="ItemIlvlBox"
                                 TextChanged="ItemIlvlBox_OnTextChanged"
                                 ToolTip="Item level предмета для весового расчёта (0 = не задан)"/>
                    </StackPanel>
                </Grid>
                <TextBlock TextWrapping="Wrap"
                           Foreground="#555"
                           Margin="0,0,0,10"
                           Text="Между «Вариант N» — ИЛИ. Внутри варианта клозы связаны И. «Сумма» — сложение значений (нет модификатора — 0). «Набор (COUNT)» — сколько строк из списка должно выполняться на предмете одновременно (каждая строка как одиночный аффикс)."/>
                <StackPanel x:Name="OrAlternativesHost" Margin="0,0,0,8"/>
                <TextBlock x:Name="TheoryChanceLabel"
                           Margin="0,0,0,2"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#1976D2"/>
                <TextBlock x:Name="PracticeChanceLabel"
                           Margin="0,0,0,10"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#388E3C"/>
                <Button Content="Добавить вариант (ИЛИ)…"
                        HorizontalAlignment="Left"
                        Padding="10,6"
                        Click="AddOrAlternative_OnClick"/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
