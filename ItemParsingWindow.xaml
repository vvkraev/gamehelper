<Window x:Class="GameHelper.ItemParsingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Item Parser - Разбор предмета"
        Height="600"
        Width="700"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Item Name -->
        <TextBlock Grid.Row="0" Text="Название предмета:" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="ItemNameTextBox" 
                 Grid.Row="0" 
                 IsReadOnly="True"
                 Margin="0,20,0,12"
                 Padding="8"
                 Background="White"
                 FontSize="14"
                 FontWeight="Bold"/>

        <!-- Item Type -->
        <TextBlock Grid.Row="1" Text="Тип/Редкость:" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="ItemTypeTextBox" 
                 Grid.Row="1" 
                 IsReadOnly="True"
                 Margin="0,20,0,12"
                 Padding="8"
                 Background="White"/>

        <!-- Item Properties Label -->
        <TextBlock Grid.Row="2" Text="Свойства предмета:" FontWeight="SemiBold" Margin="0,0,0,4"/>

        <!-- Item Properties -->
        <ScrollViewer Grid.Row="3" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Margin="0,0,0,12">
            <TextBox x:Name="ItemPropertiesTextBox" 
                     IsReadOnly="True"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     Padding="8"
                     Background="White"
                     FontFamily="Consolas"
                     FontSize="11"/>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="4"
                Content="Закрыть"
                Width="100"
                Padding="12,6"
                Click="CloseButton_Click"
                HorizontalAlignment="Right"/>
    </Grid>
</Window>