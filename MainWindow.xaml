                </StackPanel>

                <!-- Результаты -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16,0,16,16">
                    <StackPanel x:Name="NetworthResultsPanel"/>
                </ScrollViewer>
            </Grid>
        </TabItem>

        <TabItem x:Name="TabAppSettings" Header="Настройки приложения">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16">
                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Задержка после перемещения мыши и после клика, мс (одно значение для всех шагов Move, ЛКМ, ПКМ)"/>
                    <TextBox x:Name="MouseActionDelayMs" Margin="0,0,0,12" Text="80"/>

                    <TextBlock Text="Задержка после Ctrl+Alt+C перед чтением буфера, мс" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBox x:Name="ClipboardDelayMs" Margin="0,0,0,12" Text="220"/>

                    <StackPanel Margin="0,0,0,12">
                        <CheckBox x:Name="TraceInputCheckBox"
                                  Margin="0,0,0,8"
                                  Content="Подробный лог ввода (отладка: шаги мыши/клавиш и позиция курсора)"
                                  ToolTip="Включите и смотрите окно лога или файл Log/session_… после закрытия приложения. Рекомендуется запуск отладки F5 из Cursor."/>

                        <CheckBox x:Name="StepConfirmCheckBox"
                                  Margin="0,0,0,0"
                                  Content="Пошаговое подтверждение: окно после каждого действия (Enter = Продолжить)"
                                  ToolTip="Для отладки. Закрытие окна крестиком отменяет цикл (Стоп). В бою с игрой обычно выключено."/>

                        <CheckBox x:Name="TraceExaltationSchemaCheckBox"
                                  Margin="0,8,0,0"
                                  Content="Трассировка схемы экзальт-крафта ([ExaltSchema] в логе — узел ASCII-флоу)"
                                  ToolTip="Только для режима Orb of Exaltation (Fractured). В лог пишутся строки [ExaltSchema] … с якорем на docs/EXALTATION_CRAFT_SERVICE_FRACTURED_SIDE_FLOW_ASCII.txt. Сочетайте с F5 и подробным логом ввода при необходимости."/>

                        <CheckBox x:Name="KillPoeAfterCraftCheckBox"
                                  Margin="0,8,0,0"
                                  Content="Завершить процесс PathOfExileSteam.exe после завершения крафта"
                                  ToolTip="Не сохраняется. Если включено — после завершения крафта по любой причине будет выполнено завершение процесса игры."/>
                    </StackPanel>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Цены poe.ninja -->
                    <TextBlock Text="Цены poe.ninja" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Лига:" VerticalAlignment="Center"/>
                        <TextBox x:Name="PoeNinjaLeagueBox" Grid.Column="1" Padding="4,2" Margin="0,0,8,0" Text="Standard"/>
                        <Button Grid.Column="2" Content="Загрузить цены" Padding="6,4" Click="PoeNinjaFetchBtn_Click"/>
                    </Grid>
                    <TextBlock x:Name="PoeNinjaStatusText" FontSize="11" Foreground="#555" Margin="0,0,0,12" Text="Цены не загружены."/>

                    <Separator Margin="0,0,0,12"/>

                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Горячая клавиша «Свернуть / развернуть в трей» (кликните в поле и нажмите комбинацию; Esc — сбросить):"/>
                    <TextBox x:Name="TrayHotkeyBox"
                             IsReadOnly="True"
                             Cursor="Arrow"
                             Margin="0,0,0,12"
                             Text="(не задано)"
                             PreviewKeyDown="TrayHotkeyBox_PreviewKeyDown"
                             ToolTip="Работает глобально — сворачивает и разворачивает окно без фокуса на приложении."/>

                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Горячая клавиша «Открыть лог крафта» (кликните в поле и нажмите комбинацию; Esc — сбросить):"/>
                    <TextBox x:Name="OpenLogHotkeyBox"
                             IsReadOnly="True"
                             Cursor="Arrow"
                             Margin="0,0,0,12"
                             Text="(не задано)"
                             PreviewKeyDown="OpenLogHotkeyBox_PreviewKeyDown"
                             ToolTip="Работает глобально — открывает файл текущего или последнего крафта."/>

                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Горячая клавиша «Старт / Стоп крафта» (кликните в поле и нажмите комбинацию; Esc — сбросить):"/>
                    <TextBox x:Name="CraftStartStopHotkeyBox"
                             IsReadOnly="True"
                             Cursor="Arrow"
                             Margin="0,0,0,12"
                             Text="(не задано)"
                             PreviewKeyDown="CraftStartStopHotkeyBox_PreviewKeyDown"
                             ToolTip="Работает глобально — запускает крафт если он не идёт, или останавливает если идёт."/>

                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Горячая клавиша «Старт / Стоп перековки» (кликните в поле и нажмите комбинацию; Esc — сбросить):"/>
                    <TextBox x:Name="ReforgeStartStopHotkeyBox"
                             IsReadOnly="True"
                             Cursor="Arrow"
                             Margin="0,0,0,12"
                             Text="(не задано)"
                             PreviewKeyDown="ReforgeStartStopHotkeyBox_PreviewKeyDown"
                             ToolTip="Работает глобально — запускает перековку если она не идёт, или останавливает если идёт."/>

                    <TextBlock FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Горячая клавиша «Старт / Стоп Networth» (кликните в поле и нажмите комбинацию; Esc — сбросить):"/>
                    <TextBox x:Name="NetworthStartStopHotkeyBox"
                             IsReadOnly="True"
                             Cursor="Arrow"
                             Margin="0,0,0,12"
                             Text="(не задано)"
                             PreviewKeyDown="NetworthStartStopHotkeyBox_PreviewKeyDown"
                             ToolTip="Работает глобально — запускает Networth-сканирование (сворачивает окно) или останавливает его."/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="MinimizeToTrayBtn"
                                Content="В трей"
                                Width="90"
                                Margin="0,0,0,0"
                                Click="MinimizeToTray_OnClick"
                                ToolTip="Скрыть окно в область уведомлений (иконка у часов). ПКМ по иконке — меню."/>
                        <Button x:Name="OpenLogBtn"
                                Content="Открыть лог крафта"
                                Margin="8,0,0,0"
                                Click="OpenLogBtn_OnClick"
                                ToolTip="Открыть файл текущего крафта (если запущен) или последнего завершённого крафта."/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4">
                        Лог в окне; полный лог крафта (буфер vs строка пользователя) — файл в папке Log проекта после каждого «Старт». Сессионный лог — при закрытии приложения.
                    </TextBlock>
                    <TextBox x:Name="LogBox"
                             MinHeight="200"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             SnapsToDevicePixels="True"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
