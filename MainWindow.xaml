<Window x:Class="GameHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="pack://application:,,,/app.ico"
        Title="GameHelper — PoE2 Chaos craft (MVP)"
        Height="620"
        Width="600"
        MinHeight="440"
        MinWidth="500"
        Topmost="True"
        ShowActivated="False"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <!-- Вкладки слева: длинные русские заголовки не исчезают из-за нехватки ширины одной строки -->
    <TabControl x:Name="MainTabs" Margin="12" TabStripPlacement="Left">
        <TabItem x:Name="TabRegionSettings" Header="Настройки областей">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" HorizontalAlignment="Stretch">
                    <Expander x:Name="CurrencyExpander" Header="Currency" IsExpanded="False" Margin="0,0,0,14">
                        <StackPanel x:Name="CurrencyExpanderContent" Margin="0,0,0,0">
                            <TextBlock Text="Вкладка инвентаря Currency" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="CurrencyInventoryInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickCurrencyInventoryBtn"
                                    Content="Задать область (вкладка инвентаря Currency)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickCurrencyInventoryBtn_OnClick"/>

                            <Separator Margin="0,4,0,10"/>
                            <TextBlock Text="Области предметов Currency (Networth)" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBlock Text="Задайте область для каждого предмета, который хотите учитывать в Networth."
                                       TextWrapping="Wrap" Foreground="#666" FontSize="11" Margin="0,0,0,8"/>
                            <StackPanel x:Name="CurrencyItemRegionsPanel"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="RitualExpander" Header="Ritual" IsExpanded="False">
                        <StackPanel x:Name="RitualExpanderContent">
                            <TextBlock Text="Вкладка инвентаря Ritual" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="RitualInventoryInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickRitualInventoryBtn"
                                    Content="Задать область (вкладка инвентаря Ritual)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickRitualInventoryBtn_OnClick"/>

                            <TextBlock Text="Omen of Sinistral Exaltation Stash" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <TextBlock x:Name="OmenSinistralStashInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOmenSinistralStashBtn"
                                    Content="Задать область (Omen of Sinistral Exaltation Stash)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOmenSinistralStashBtn_OnClick"/>

                            <TextBlock Text="Omen of Dextral Exaltation Stash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="OmenDextralStashInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOmenDextralStashBtn"
                                    Content="Задать область (Omen of Dextral Exaltation Stash)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOmenDextralStashBtn_OnClick"/>

                            <TextBlock Text="Omen of Greater Exaltation Stash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="OmenGreaterStashInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOmenGreaterStashBtn"
                                    Content="Задать область (Omen of Greater Exaltation Stash)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOmenGreaterStashBtn_OnClick"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="BreachExpander" Header="Breach (катализаторы)" IsExpanded="False" Margin="0,14,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <!-- Область вкладки Breach Stash -->
                            <TextBlock Text="Вкладка Breach Stash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Область вкладки:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BreachInventoryInfo" Grid.Column="1"
                                           Text="не задана" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="11"/>
                                <Button Grid.Column="2" Content="Задать…" Padding="8,4"
                                        Click="PickBreachInventoryBtn_Click"/>
                            </Grid>
                            <Separator Margin="0,0,0,10"/>
                            <!-- Области отдельных катализаторов — заполняется динамически -->
                            <TextBlock Text="Области катализаторов" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel x:Name="BreachCatalystRegionsPanel"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="DeliriumExpander" Header="Delirium (Liquid Orbs)" IsExpanded="False" Margin="0,14,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <!-- Область вкладки Delirium Stash -->
                            <TextBlock Text="Вкладка Delirium Stash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Область вкладки:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeliriumInventoryInfo" Grid.Column="1"
                                           Text="не задана" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="11"/>
                                <Button Grid.Column="2" Content="Задать…" Padding="8,4"
                                        Click="PickDeliriumInventoryBtn_Click"/>
                            </Grid>
                            <Separator Margin="0,0,0,10"/>
                            <!-- Области отдельных предметов делирия — заполняется динамически -->
                            <TextBlock Text="Области предметов" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel x:Name="DeliriumItemRegionsPanel"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="AutoReforgeNavExpander" Header="Навигация (авто-перековка)" IsExpanded="False" Margin="0,14,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,8"
                                       Text="OCR ищет текст метки в заданной области. Область поиска — прямоугольник где эта надпись появляется на экране (например над объектом или в UI подсказке)."/>

                            <!-- STASH -->
                            <TextBlock Text="STASH" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Текст для поиска:" VerticalAlignment="Center"/>
                                <TextBox x:Name="StashOcrTextBox" Text="STASH" Grid.Column="1" Padding="4,2"/>
                            </Grid>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Область поиска:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="StashOcrSearchInfo" Grid.Column="1"
                                           Text="не задана" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="11"/>
                                <Button Grid.Column="2" Content="Задать…" Padding="8,4"
                                        Click="PickStashOcrSearchBtn_Click"/>
                            </Grid>

                            <Separator Margin="0,0,0,10"/>

                            <!-- Reforging Bench -->
                            <TextBlock Text="Reforging Bench" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Текст для поиска:" VerticalAlignment="Center"/>
                                <TextBox x:Name="ReforgingBenchOcrTextBox" Text="Reforging" Grid.Column="1" Padding="4,2"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Область поиска:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ReforgingBenchOcrSearchInfo" Grid.Column="1"
                                           Text="не задана" VerticalAlignment="Center"
                                           Foreground="#555" FontSize="11"/>
                                <Button Grid.Column="2" Content="Задать…" Padding="8,4"
                                        Click="PickReforgingBenchOcrSearchBtn_Click"/>
                            </Grid>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="TraderNpcOcrExpander" Header="Торговец (OCR имени)" IsExpanded="False" Margin="0,14,0,0">
                        <StackPanel x:Name="TraderNpcOcrExpanderContent">
                            <TextBlock x:Name="TraderNpcOcrHintTextBlock"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"
                                       Foreground="#444"
                                       Text="Выделите область, где видна чёрная плашка с именем NPC (например ANGE). Затем — кнопка ниже: OCR найдёт текст, курсор встанет в центр подписи, выполнится Ctrl+ЛКМ (открытие торговли в PoE2). Окно GameHelper не должно перекрывать игру — сверните его или снимите «поверх всех»."/>
                            <TextBlock x:Name="TraderNameOcrRegionLabel" Text="Область поиска имени" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="TraderNameOcrRegionInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickTraderNameOcrRegionBtn"
                                    Content="Задать область (имя NPC над торговцем)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickTraderNameOcrRegionBtn_OnClick"/>
                            <TextBlock x:Name="TraderNpcNameLabel" Text="Имя для поиска (как на экране)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBox x:Name="TraderNpcNameTextBox"
                                     Margin="0,0,0,12"
                                     Text="ANGE"/>
                            <Button x:Name="TraderNpcOpenTradeOcrBtn"
                                    Content="Найти имя (OCR) и Ctrl+ЛКМ — открыть торговлю"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,0"
                                    Click="TraderNpcOpenTradeOcrBtn_OnClick"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem x:Name="TabInventoryLayout" Header="Разметка инвентаря">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" HorizontalAlignment="Stretch">

                    <!-- Полный инвентарь 12×5 -->
                    <TextBlock Text="Полный инвентарь (12×5)" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,8"
                               Text="Все 60 ячеек инвентаря персонажа (12 столбцов × 5 строк). Используется в авто-режиме перековки: сканирование катализаторов и сброс в стэш (Ctrl+ПКМ). Выберите правый нижний угол инвентаря при открытом стэше или станке."/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="FullInventoryGridInfo"
                                   Text="не задана" VerticalAlignment="Center"
                                   Foreground="#555" FontSize="11" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Задать сетку 12×5…" Padding="12,6"
                                Click="PickFullInventoryGridBtn_Click"/>
                    </Grid>
                    <Separator Margin="0,12,0,12"/>

                    <TextBlock Text="Область в инвентаре для Omen of Sinistral Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="OmenSinistralInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickOmenSinistralBtn"
                            Content="Задать область в инвентаре (Omen of Sinistral Exaltation)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickOmenSinistralBtn_OnClick"/>

                    <TextBlock Text="Область в инвентаре для Omen of Dextral Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="OmenDextralInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickOmenDextralBtn"
                            Content="Задать область в инвентаре (Omen of Dextral Exaltation)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickOmenDextralBtn_OnClick"/>

                    <TextBlock Text="Область в инвентаре для Omen of Greater Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="OmenGreaterInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickOmenGreaterBtn"
                            Content="Задать область в инвентаре (Omen of Greater Exaltation)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickOmenGreaterBtn_OnClick"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem x:Name="TabCraft" Header="Крафт">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" HorizontalAlignment="Stretch">
                    <TextBlock Text="Область предмета" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ItemInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickItemBtn"
                            Content="Задать область (предмет)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickItemBtn_OnClick"/>
                    <Button x:Name="ItemParsingBtn"
                            Content="Распарсить предмет"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,6"
                            Click="ItemParsing_OnClick"/>

                    <Button x:Name="ReloadAffixLibraryBtn"
                            Content="Перезагрузить библиотеку аффиксов из файла…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="ReloadAffixLibrary_OnClick"
                            ToolTip="Файл affix_library.json в папке проекта (рядом с .csproj). Можно править в блокноте."/>

                    <TextBlock Text="Режим крафта" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CraftModeCombo"
                              Margin="0,0,0,12"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Хаос"/>
                        <ComboBoxItem Content="Экзальт"/>
                        <ComboBoxItem Content="Ауг+Аннул"/>
                        <ComboBoxItem Content="Заточка"/>
                    </ComboBox>

                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Условие остановки крафта (affix_library.json, класс предмета внутри условия)"/>
                    <TextBlock x:Name="CraftConditionSummary"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Foreground="#333"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="CraftConditionBtn"
                                Content="Настроить условие…"
                                Padding="12,6"
                                Click="CraftConditionBtn_OnClick"/>
                        <Button x:Name="ClearCraftConditionBtn" Content="Очистить условие"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                Click="ClearCraftCondition_OnClick"
                                ToolTip="Сбросить текущее условие остановки крафта (класс + все И/ИЛИ-ветки)."/>
                        <Button x:Name="CopyCraftConditionForReportBtn" Content="Копировать для отчёта…"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                Click="CopyCraftConditionForReport_OnClick"
                                ToolTip="Краткий текст и JSON условия в буфер обмена — можно вставить в сообщение об ошибке или в чат."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="SaveRecipeBtn" Content="Сохранить рецепт…"
                                Padding="12,6"
                                Click="SaveRecipe_OnClick"
                                ToolTip="Сохранить текущее условие крафта в отдельный файл (папка Recipes рядом с проектом)."/>
                        <Button x:Name="LoadRecipeBtn" Content="Загрузить рецепт…"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                Click="LoadRecipe_OnClick"
                                ToolTip="Загрузить условие крафта из файла рецепта (заменит текущее условие в программе)."/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Максимум операций (N) — общий на всю сессию (все ячейки сетки)"/>
                    <TextBox x:Name="MaxOps" Margin="0,0,0,12" Text="20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="StartBtn" Content="Старт" Width="100" Margin="0,0,8,0" Click="StartBtn_OnClick"/>
                        <Button x:Name="StopBtn"
                                Content="Стоп"
                                Width="100"
                                IsEnabled="False"
                                Click="StopBtn_OnClick"
                                ToolTip="Прервать крафт. Во время сессии крафта Esc зарегистрирован глобально (работает без фокуса на этом окне и в трее)."/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <!-- ═══ ВКЛАДКА ПЕРЕКОВКА ════════════════════════════════════════════ -->
        <TabItem x:Name="TabReforge" Header="Перековка">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="14">

                    <!-- Сетка инвентаря -->
                    <TextBlock Text="Сетка инвентаря" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,6"
                               Text="Область ячеек с катализаторами в инвентаре. Используется и для сканирования реестра, и для перековки."/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Сетка:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="RfScanGridInfo" Grid.Column="1" VerticalAlignment="Center"
                                   Foreground="#555" FontSize="11"/>
                        <Button Grid.Column="2" Content="Задать сетку…" Padding="8,4" Click="RfPickScanGrid_Click"/>
                    </Grid>

                    <Separator Margin="0,0,0,12"/>

                    <!-- Области станка -->
                    <TextBlock Text="Области станка" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Слот 1 входа:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RfSlot1Info" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
                        <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="RfPickSlot1_Click"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Слот 2 входа:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RfSlot2Info" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
                        <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="RfPickSlot2_Click"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Слот 3 входа:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RfSlot3Info" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
                        <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="RfPickSlot3_Click"/>
                    </Grid>
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Кнопка Reforge:" VerticalAlignment="Center"/>
                        <TextBlock x:Name="RfConfirmInfo" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
                        <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="RfPickConfirm_Click"/>
                    </Grid>
