<Window x:Class="GameHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameHelper — PoE2 Chaos craft (MVP)"
        Height="620"
        Width="520"
        MinHeight="440"
        MinWidth="480"
        Topmost="True"
        ShowActivated="False"
        PreviewKeyDown="MainWindow_OnPreviewKeyDown">
    <TabControl x:Name="MainTabs" Margin="12">
        <TabItem x:Name="TabRegionSettings" Header="Настройки областей">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" HorizontalAlignment="Stretch">
                    <Expander x:Name="CurrencyExpander" Header="Currency" IsExpanded="True" Margin="0,0,0,14">
                        <StackPanel x:Name="CurrencyExpanderContent" Margin="0,0,0,0">
                            <TextBlock Text="Вкладка инвентаря Currency" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="CurrencyInventoryInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickCurrencyInventoryBtn"
                                    Content="Задать область (вкладка инвентаря Currency)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickCurrencyInventoryBtn_OnClick"/>

                            <TextBlock Text="Область Chaos Orb" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="OrbInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOrbBtn"
                                    Content="Задать область (Chaos Orb)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOrbBtn_OnClick"/>

                            <TextBlock Text="Область Orb of Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="ExaltInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickExaltBtn"
                                    Content="Задать область (Orb of Exaltation)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickExaltBtn_OnClick"/>

                            <TextBlock Text="Область Orb of Annulment" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="AnnulInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickAnnulBtn"
                                    Content="Задать область (Orb of Annulment)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickAnnulBtn_OnClick"/>

                            <TextBlock Text="Область Orb of Augmentation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="AugInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickAugBtn"
                                    Content="Задать область (Orb of Augmentation)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickAugBtn_OnClick"/>

                            <TextBlock Text="Заточка" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="SharpenInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickSharpenBtn"
                                    Content="Задать область (заточка)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickSharpenBtn_OnClick"/>
                        </StackPanel>
                    </Expander>

                    <Expander x:Name="RitualExpander" Header="Ritual" IsExpanded="True">
                        <StackPanel x:Name="RitualExpanderContent">
                            <TextBlock Text="Вкладка инвентаря Ritual" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="RitualInventoryInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickRitualInventoryBtn"
                                    Content="Задать область (вкладка инвентаря Ritual)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickRitualInventoryBtn_OnClick"/>

                            <TextBlock Text="Omen of Sinistral Exaltation Stash" FontWeight="SemiBold" Margin="0,10,0,4"/>
                            <TextBlock x:Name="OmenSinistralStashInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOmenSinistralStashBtn"
                                    Content="Задать область (Omen of Sinistral Exaltation Stash)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOmenSinistralStashBtn_OnClick"/>

                            <TextBlock Text="Omen of Dextral Exaltation Stash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="OmenDextralStashInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOmenDextralStashBtn"
                                    Content="Задать область (Omen of Dextral Exaltation Stash)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOmenDextralStashBtn_OnClick"/>

                            <TextBlock Text="Omen of Greater Exaltation Stash" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <TextBlock x:Name="OmenGreaterStashInfo"
                                       Text="не задана — нажмите кнопку ниже"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"
                                       Foreground="#555"/>
                            <Button x:Name="PickOmenGreaterStashBtn"
                                    Content="Задать область (Omen of Greater Exaltation Stash)…"
                                    HorizontalAlignment="Left"
                                    Padding="12,6"
                                    Margin="0,0,0,12"
                                    Click="PickOmenGreaterStashBtn_OnClick"/>
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem x:Name="TabInventoryLayout" Header="Разметка инвентаря">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" HorizontalAlignment="Stretch">
                    <TextBlock Text="Область в инвентаре для Omen of Sinistral Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="OmenSinistralInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickOmenSinistralBtn"
                            Content="Задать область в инвентаре (Omen of Sinistral Exaltation)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickOmenSinistralBtn_OnClick"/>

                    <TextBlock Text="Область в инвентаре для Omen of Dextral Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="OmenDextralInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickOmenDextralBtn"
                            Content="Задать область в инвентаре (Omen of Dextral Exaltation)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickOmenDextralBtn_OnClick"/>

                    <TextBlock Text="Область в инвентаре для Omen of Greater Exaltation" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="OmenGreaterInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickOmenGreaterBtn"
                            Content="Задать область в инвентаре (Omen of Greater Exaltation)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickOmenGreaterBtn_OnClick"/>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem x:Name="TabCraft" Header="Крафт">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" HorizontalAlignment="Stretch">
                    <TextBlock Text="Область предмета" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <TextBlock x:Name="ItemInfo"
                               Text="не задана — сначала X×Y сетки, затем выделение области"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="#555"/>
                    <Button x:Name="PickItemBtn"
                            Content="Задать область (предмет)…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="PickItemBtn_OnClick"/>
                    <Button x:Name="ItemParsingBtn"
                            Content="Распарсить предмет"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,6"
                            Click="ItemParsing_OnClick"/>

                    <Button x:Name="ReloadAffixLibraryBtn"
                            Content="Перезагрузить библиотеку аффиксов из файла…"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Margin="0,0,0,12"
                            Click="ReloadAffixLibrary_OnClick"
                            ToolTip="Файл affix_library.json в папке проекта (рядом с .csproj). Можно править в блокноте."/>

                    <TextBlock Text="Режим крафта" FontWeight="SemiBold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CraftModeCombo"
                              Margin="0,0,0,12"
                              SelectedIndex="0">
                        <ComboBoxItem Content="Хаос"/>
                        <ComboBoxItem Content="Экзальт"/>
                        <ComboBoxItem Content="Ауг+Аннул"/>
                        <ComboBoxItem Content="Заточка"/>
                    </ComboBox>

                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Условие остановки крафта (affix_library.json, класс предмета внутри условия)"/>
                    <TextBlock x:Name="CraftConditionSummary"
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"
                               Foreground="#333"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="CraftConditionBtn"
                                Content="Настроить условие…"
                                Padding="12,6"
                                Click="CraftConditionBtn_OnClick"/>
                        <Button x:Name="ClearCraftConditionBtn" Content="Очистить условие"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                Click="ClearCraftCondition_OnClick"
                                ToolTip="Сбросить текущее условие остановки крафта (класс + все И/ИЛИ-ветки)."/>
                        <Button x:Name="CopyCraftConditionForReportBtn" Content="Копировать для отчёта…"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                Click="CopyCraftConditionForReport_OnClick"
                                ToolTip="Краткий текст и JSON условия в буфер обмена — можно вставить в сообщение об ошибке или в чат."/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="SaveRecipeBtn" Content="Сохранить рецепт…"
                                Padding="12,6"
                                Click="SaveRecipe_OnClick"
                                ToolTip="Сохранить текущее условие крафта в отдельный файл (папка Recipes рядом с проектом)."/>
                        <Button x:Name="LoadRecipeBtn" Content="Загрузить рецепт…"
                                Padding="12,6"
                                Margin="12,0,0,0"
                                Click="LoadRecipe_OnClick"
                                ToolTip="Загрузить условие крафта из файла рецепта (заменит текущее условие в программе)."/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4"
                               Text="Максимум операций (N) — общий на всю сессию (все ячейки сетки)"/>
                    <TextBox x:Name="MaxOps" Margin="0,0,0,12" Text="20"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="StartBtn" Content="Старт" Width="100" Margin="0,0,8,0" Click="StartBtn_OnClick"/>
                        <Button x:Name="StopBtn"
                                Content="Стоп"
                                Width="100"
                                IsEnabled="False"
                                Click="StopBtn_OnClick"
                                ToolTip="Прервать крафт. Во время сессии крафта Esc зарегистрирован глобально (работает без фокуса на этом окне и в трее)."/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem x:Name="TabAppSettings" Header="Настройки приложения">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           Text="Задержка после перемещения мыши и после клика, мс (одно значение для всех шагов Move, ЛКМ, ПКМ)"/>
                <TextBox Grid.Row="1" x:Name="MouseActionDelayMs" Margin="0,0,0,12" Text="80"/>

                <TextBlock Grid.Row="2" Text="Задержка после Ctrl+Alt+C перед чтением буфера, мс" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox Grid.Row="3" x:Name="ClipboardDelayMs" Margin="0,0,0,12" Text="220"/>

                <StackPanel Grid.Row="4" Margin="0,0,0,12">
                    <CheckBox x:Name="TraceInputCheckBox"
                              Margin="0,0,0,8"
                              Content="Подробный лог ввода (отладка: шаги мыши/клавиш и позиция курсора)"
                              ToolTip="Включите и смотрите окно лога или файл Log/session_… после закрытия приложения. Рекомендуется запуск отладки F5 из Cursor."/>

                    <CheckBox x:Name="StepConfirmCheckBox"
                              Margin="0,0,0,0"
                              Content="Пошаговое подтверждение: окно после каждого действия (Enter = Продолжить)"
                              ToolTip="Для отладки. Закрытие окна крестиком отменяет цикл (Стоп). В бою с игрой обычно выключено."/>

                    <CheckBox x:Name="KillPoeAfterCraftCheckBox"
                              Margin="0,8,0,0"
                              Content="Завершить процесс PathOfExileSteam.exe после завершения крафта"
                              ToolTip="Не сохраняется. Если включено — после завершения крафта по любой причине будет выполнено завершение процесса игры."/>
                </StackPanel>

                <StackPanel Grid.Row="5">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button x:Name="MinimizeToTrayBtn"
                                Content="В трей"
                                Width="90"
                                Margin="0,0,0,0"
                                Click="MinimizeToTray_OnClick"
                                ToolTip="Скрыть окно в область уведомлений (иконка у часов). ПКМ по иконке — меню."/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,0,0,4">
                        Лог в окне; полный лог крафта (буфер vs строка пользователя) — файл в папке Log проекта после каждого «Старт». Сессионный лог — при закрытии приложения.
                    </TextBlock>
                    <TextBox x:Name="LogBox"
                             MinHeight="160"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas"
                             SnapsToDevicePixels="True"/>
                </StackPanel>
            </Grid>
        </TabItem>
    </TabControl>
</Window>
