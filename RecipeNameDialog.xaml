<Window x:Class="GameHelper.RecipeNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сохранить рецепт"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   TextWrapping="Wrap"
                   Margin="0,0,0,8"
                   MaxWidth="380"
                   Text="Введите имя рецепта. Он будет сохранён отдельным файлом в папке Recipes рядом с проектом."/>

        <TextBox x:Name="NameBox"
                 Grid.Row="1"
                 MinWidth="360"
                 Margin="0,0,0,12"
                 VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveBtn" Content="Сохранить" Width="110" Margin="0,0,8,0" IsDefault="True" Click="Save_OnClick"/>
            <Button x:Name="CancelBtn" Content="Отмена" Width="90" IsCancel="True" Click="Cancel_OnClick"/>
        </StackPanel>
    </Grid>
</Window>

