<Window x:Class="GameHelper.ReforgeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Перековка (Reforge)"
        Width="580" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="14">

        <!-- Сетка инвентаря -->
        <TextBlock Text="Сетка инвентаря" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,6"
                   Text="Область ячеек с катализаторами в инвентаре. Используется и для сканирования реестра, и для перековки."/>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Сетка:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock x:Name="ScanGridInfo" Grid.Column="1" VerticalAlignment="Center"
                       Foreground="#555" FontSize="11"/>
            <Button Grid.Column="2" Content="Задать сетку…" Padding="8,4" Click="PickScanGrid_Click"/>
        </Grid>

        <Separator Margin="0,0,0,12"/>

        <!-- Области станка -->
        <TextBlock Text="Области станка" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Слот 1 входа:" VerticalAlignment="Center"/>
            <TextBlock x:Name="Slot1Info" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
            <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="PickSlot1_Click"/>
        </Grid>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Слот 2 входа:" VerticalAlignment="Center"/>
            <TextBlock x:Name="Slot2Info" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
            <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="PickSlot2_Click"/>
        </Grid>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Слот 3 входа:" VerticalAlignment="Center"/>
            <TextBlock x:Name="Slot3Info" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
            <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="PickSlot3_Click"/>
        </Grid>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Кнопка Reforge:" VerticalAlignment="Center"/>
            <TextBlock x:Name="ConfirmInfo" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
            <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="PickConfirm_Click"/>
        </Grid>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Область результата:" VerticalAlignment="Center"/>
            <TextBlock x:Name="ResultInfo" Grid.Column="1" VerticalAlignment="Center" Foreground="#555" FontSize="11"/>
            <Button Grid.Column="2" Content="Задать…" Padding="8,4" Click="PickResult_Click"/>
        </Grid>

        <Separator Margin="0,0,0,12"/>

        <!-- Катализаторы для перековки -->
        <TextBlock Text="Катализаторы для перековки" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
        <TextBlock TextWrapping="Wrap" Foreground="#555" FontSize="11" Margin="0,0,0,6"
                   Text="Отметьте типы, которые нужно перековывать. Реестр пополняется кнопкой «Сканировать реестр»."/>
        <Grid Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="CatalystSelectionStatus" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
            <Button Grid.Column="1" Content="Снять все" Padding="8,3"
                    Click="DeselectAllCatalysts_Click"/>
        </Grid>
        <ListBox x:Name="CatalystCheckList" Height="130" BorderBrush="#CCC" BorderThickness="1" Margin="0,0,0,12"/>

        <Separator Margin="0,0,0,12"/>

        <!-- Задержки и параметры -->
        <TextBlock Text="Параметры" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Клик мыши (мс):" VerticalAlignment="Center"/>
            <TextBox x:Name="MouseDelayBox" Text="80" Width="70" HorizontalAlignment="Left" Grid.Column="1" Padding="4,2"/>
        </Grid>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Буфер обмена (мс):" VerticalAlignment="Center"/>
            <TextBox x:Name="ClipDelayBox" Text="220" Width="70" HorizontalAlignment="Left" Grid.Column="1" Padding="4,2"/>
        </Grid>
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Анимация станка (мс):" VerticalAlignment="Center"/>
            <TextBox x:Name="PostAnimDelayBox" Text="800" Width="70" HorizontalAlignment="Left" Grid.Column="1" Padding="4,2"/>
        </Grid>
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Макс. перековок (0 = без огр.):" VerticalAlignment="Center"/>
            <TextBox x:Name="MaxOpsBox" Text="0" Width="70" HorizontalAlignment="Left" Grid.Column="1" Padding="4,2"/>
        </Grid>

        <Separator Margin="0,0,0,12"/>

        <!-- Реестр -->
        <TextBlock Text="Реестр катализаторов" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="ScanGridBtn" Content="▶ Сканировать реестр" Padding="10,6"
                    Margin="0,0,8,0" Click="ScanGridBtn_Click"/>
            <Button Content="Очистить реестр" Padding="10,6" Click="ClearRegistryBtn_Click"/>
            <TextBlock x:Name="RegistryScanStatus" VerticalAlignment="Center"
                       Margin="12,0,0,0" FontSize="11" Foreground="#555"/>
        </StackPanel>

        <Separator Margin="0,0,0,12"/>

        <!-- Управление -->
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <CheckBox x:Name="DebugParseCheckBox" Content="Показывать окно парсинга (отладка)"
                      VerticalAlignment="Center" IsChecked="False"/>
            <Button x:Name="StartBtn" Grid.Column="1" Content="▶ Старт" Width="90"
                    Margin="0,0,8,0" Padding="8,6" Click="StartBtn_Click"
                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button x:Name="StopBtn" Grid.Column="2" Content="⏹ Стоп" Width="90"
                    Margin="0,0,8,0" Padding="8,6" Click="StopBtn_Click" IsEnabled="False"/>
            <Button Grid.Column="3" Content="✕ Закрыть" Width="90" Padding="8,6" Click="CloseBtn_Click"/>
        </Grid>

        <!-- Лог -->
        <TextBlock Text="Лог" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
        <ScrollViewer Height="160" VerticalScrollBarVisibility="Auto">
            <TextBox x:Name="LogBox" IsReadOnly="True" TextWrapping="Wrap"
                     FontFamily="Consolas" FontSize="11"
                     Background="#F5F5F5" BorderThickness="1" BorderBrush="#CCC" Padding="4"/>
        </ScrollViewer>

    </StackPanel>
</Window>
